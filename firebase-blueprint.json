{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the Chairman",
      "type": "object",
      "properties": {
        "officeName": { "type": "string" },
        "focus": { "type": "string" },
        "provisionedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["officeName", "role"]
    },
    "Agent": {
      "title": "AI Agent",
      "description": "Resident or sub-agent in the Viabhron OS",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "status": { "type": "string" },
        "isResident": { "type": "boolean" },
        "isStaff": { "type": "boolean" },
        "color": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "role", "status"]
    },
    "Secret": {
      "title": "Sovereign Secret",
      "description": "Encrypted API keys or sensitive strings",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["label", "value", "type"]
    },
    "Moss": {
      "title": "Moss App",
      "description": "Mini-app or micro-service available in the landscape",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "status": { "type": "string" },
        "isFrozen": { "type": "boolean" }
      },
      "required": ["name", "status"]
    },
    "Tab": {
      "title": "Browser Tab",
      "description": "Represents an open interface session in the Sovereign Shell",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "active": { "type": "boolean" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "type", "status"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "Log of interaction between user and agent",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "role": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "role"]
    }
  },
  "firestore": {
    "/users/{userId}/settings/identity": {
      "schema": "User",
      "description": "Chairman's sovereign identity settings"
    },
    "/users/{userId}/agents/{agentId}": {
      "schema": "Agent",
      "description": "Agents owned by the Chairman"
    },
    "/users/{userId}/secrets/{secretId}": {
      "schema": "Secret",
      "description": "Secrets stored by the Chairman"
    },
    "/users/{userId}/moss/{mossId}": {
      "schema": "Moss",
      "description": "Apps installed/managed by the Chairman"
    },
    "/users/{userId}/tabs/{tabId}": {
      "schema": "Tab",
      "description": "Sovereign Shell sessions"
    },
    "/users/{userId}/tabs/{tabId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Session history"
    }
  }
}
